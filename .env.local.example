# Copy this file to .env.local and fill in the values from Supabase.
# Settings → API → Project URL + anon public key.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Comma-separated list of emails allowed to log in (whitelist).
# Used by the login flow to accept only known users.
ALLOWED_EMAILS=rodrigo@example.com,beatriz@example.com,lucia@example.com,ines@example.com,oscar@example.com

# Service-role key (SECRETA). La usa el cron de la tasa BCV para escribir con
# permisos de servidor. NO la pongas aquí ni en el repo: va SOLO en Vercel
# (Settings → Environment Variables). Se deja documentada, sin valor, a propósito.
# SUPABASE_SERVICE_ROLE_KEY=  (configurar solo en Vercel)
